# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Privy (wallet-based auth)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# Blockchain — Base Sepolia (testnet)
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_CHAIN_ID=84532

# Blockchain — Base Mainnet (production)
# NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0x...
# NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# NEXT_PUBLIC_CHAIN_ID=8453

# Basescan (for transaction links)
NEXT_PUBLIC_BASESCAN_API_KEY=your_basescan_api_key

# Push Notifications (Web Push VAPID keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:hello@foodra.app

# EmailJS (contact form)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Weather API (optional — WeatherWidget)
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key
